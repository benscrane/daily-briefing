# Todoist
# Get from: https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=

# Google OAuth
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials → Desktop app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set automatically by: npx ts-node src/setup-gcal-auth.ts
GOOGLE_REFRESH_TOKEN=
# Leave blank to use your primary calendar
GOOGLE_CALENDAR_ID=

# Printing
# Find with: lpstat -p -d
PRINTER_NAME=
# Optional: extra lp options, e.g. "-o media=letter -o sides=one-sided"
PRINTER_OPTIONS=

# Paths & locale
# Where dated data/brief files are stored (default: ./brief_output)
DATA_DIR=
# Your local timezone (default: America/Chicago)
TIMEZONE=America/Chicago
