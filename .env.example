# Todoist
# Get from: https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=

# Google OAuth
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials → Desktop app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set automatically by: npx ts-node src/setup-gcal-auth.ts
GOOGLE_REFRESH_TOKEN=
# Leave blank to use your primary calendar
GOOGLE_CALENDAR_ID=

# AWS Bedrock (for generate_brief.py)
# Credentials: boto3 reads AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY from env,
# or from ~/.aws/credentials if those are absent.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Region for the Bedrock endpoint (default: us-east-1)
AWS_REGION=us-east-1
# Model to use — any Bedrock-accessible model ID.
# "us." prefix = US cross-region inference profile (recommended).
# Examples:
#   us.anthropic.claude-sonnet-4-6   (default)
#   us.anthropic.claude-haiku-4-5
#   us.anthropic.claude-opus-4-6
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# Max output tokens (default: 4096)
BEDROCK_MAX_TOKENS=4096

# Printing
# Find with: lpstat -p -d
PRINTER_NAME=
# Optional: extra lp options, e.g. "-o media=letter -o sides=one-sided"
PRINTER_OPTIONS=
# Total characters per printed line (default: 72)
PRINT_LINE_WIDTH=72
# Spaces to indent from the left edge (default: 4)
PRINT_LEFT_MARGIN=4

# ntfy.sh push notifications
# Topic slug from your ntfy.sh channel URL (https://ntfy.sh/<topic>)
NTFY_TOPIC=igpDbrgE5X1fJsrl

# Paths & locale
# Where dated data/brief files are stored (default: ./brief_output)
DATA_DIR=
# Your local timezone (default: America/Chicago)
TIMEZONE=America/Chicago
